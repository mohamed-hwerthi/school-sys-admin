# Development environment
VITE_API_URL=https://schooly.learnup.tn/api
VITE_APP_ENV=development
VITE_PORT=80
VITE_ENABLE_MOCK=false
# Base vide : aucun tenant par défaut (le SUPER_ADMIN se connecte sans tenant ;
# les utilisateurs d'école utilisent le tenant lié à leur compte après login).
VITE_TENANT_ID=
VITE_LOG_LEVEL=debug
VITE_DEFAULT_COUNTRY_CODE=216
