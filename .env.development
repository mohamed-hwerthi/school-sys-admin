# Development environment
VITE_API_URL=http://localhost:8083/api
VITE_APP_ENV=development
VITE_PORT=5000
VITE_ENABLE_MOCK=false
# Base vide : aucun tenant par défaut (le SUPER_ADMIN se connecte sans tenant ;
