# ═══════════════════════════════════════════════════════
# EcoleNet — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_dev_db
DB_USERNAME=med
DB_PASSWORD=med

# For docker-compose (PostgreSQL container):
POSTGRES_DB=${DB_NAME}
POSTGRES_USER=${DB_USERNAME}
POSTGRES_PASSWORD=${DB_PASSWORD}

# ─── JWT [REQUIRED in production] ─────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=aVeryLongSecretKeyThatIsAtLeast256BitsForHS256Algorithm2026!
# JWT_ACCESS_EXPIRATION_MS=900000      # 15 minutes (default)
# JWT_REFRESH_EXPIRATION_MS=604800000  # 7 days (default)

# ─── Spring Profile ────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── CORS ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Frontend URL (for email links) ────────────
FRONTEND_URL=http://localhost:5173

# ─── Frontend (Vite build-time) ────────────────
VITE_API_BASE_URL=http://localhost:8080/api

# ─── Email / SMTP [OPTIONAL] ──────────────────
MAIL_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# MAIL_FROM=noreply@ecolenet.dev

# ─── Storage [OPTIONAL] ───────────────────────
STORAGE_TYPE=local
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── AI [OPTIONAL] ────────────────────────────
AI_ENABLED=false
# AI_PROVIDER=anthropic
# AI_API_KEY=
# AI_MODEL=claude-sonnet-4-20250514

# ─── Docker (production) ──────────────────────
APP_PORT=80
